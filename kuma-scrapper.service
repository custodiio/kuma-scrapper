[Unit]
Description=Kuma Scrapper - Pipeline & Bot (Douyin/Bilibili)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/app/scrapper_douyin
ExecStart=/app/scrapper_douyin/.venv/bin/python run.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
